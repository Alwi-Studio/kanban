# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# JWT
JWT_SECRET="change-this-to-a-random-secret"
JWT_REFRESH_SECRET="change-this-to-another-random-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
# Absolute session lifetime in hours (from login). Sessions are hard-capped at
# this regardless of activity — after it elapses the user must sign in again.
SESSION_MAX_HOURS="6"

# Server
PORT=4000
NODE_ENV="development"

# CORS - comma-separated or single origin
FRONTEND_URL="http://localhost:5173"

# SMTP for password-reset emails (optional in dev — if unset, the reset link is
# logged to the server console instead of emailed). Works with any SMTP provider
# (Gmail app password, Mailgun, SendGrid, Resend SMTP, etc.).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Kanban <no-reply@example.com>"

# Staff Activity statistics (optional) — powers the "Staff Online" dashboard.
# This is a SEPARATE MySQL database (the staffactivity table), independent of the
# Postgres DATABASE_URL above. Leave unset to disable the staff stats page.
# Either provide a single connection URL:
# STATS_MYSQL_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"
# ...or the discrete variables:
# MYSQL_HOST=""
# MYSQL_PORT="3306"
# MYSQL_USER=""
# MYSQL_PASSWORD=""
# MYSQL_DATABASE=""
# MYSQL_SSL="false"
# Optional table/column overrides (defaults shown):
# MYSQL_ACTIVITY_TABLE="staffactivity"
# MYSQL_UUID_COLUMN="uuid"
# MYSQL_NAME_COLUMN="name"
# MYSQL_LAST_ACTIVITY_COLUMN="last_activity"
# MYSQL_AMOUNT_CHAT_COLUMN="amount_chat"
# MYSQL_DAY_COLUMN="day"
# MYSQL_MONTH_COLUMN="month"
# MYSQL_YEAR_COLUMN="year"

# Cloudinary (optional locally; required for durable production uploads)
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
# Alternatively, use separate variables (recommended on hosting dashboards):
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"
